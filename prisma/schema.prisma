generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Tabela de Usuários
model Usuario {
  id        Int       @id @default(autoincrement())
  nome      String
  email     String    @unique
  senha     String
  tipo      TipoUsuario
  quadras   Quadra[]
  reservas  Reserva[]
  bloqueiosFeitos    BloqueioLocatario[] @relation("LocadorBloqueios")
  bloqueiosRecebidos BloqueioLocatario[] @relation("LocatarioBloqueios")
  createdAt DateTime  @default(now())
}

// Bloqueio de locatário por locador
model BloqueioLocatario {
  id          Int      @id @default(autoincrement())
  locadorId   Int
  locador     Usuario  @relation("LocadorBloqueios", fields: [locadorId], references: [id])
  locatarioId Int
  locatario   Usuario  @relation("LocatarioBloqueios", fields: [locatarioId], references: [id])
  criadoEm   DateTime @default(now())

  @@unique([locadorId, locatarioId])
}

enum TipoUsuario {
  LOCADOR
  LOCATARIO
}

// Tabela de Quadras
model Quadra {
  id           Int       @id @default(autoincrement())
  nome         String
  valorPorHora Decimal   @db.Decimal(10, 2)
  descricao    String?   @db.Text
  imagemBlob   Bytes?    @db.LongBlob
  imagemMimeType String? @db.VarChar(100)
  endereco     String?
  cidade       String?
  estado       String?
  cep          String?
  latitude     Float?
  longitude    Float?
  horasAntecedenciaCancelamento Int     @default(6)
  requerAprovacao               Boolean @default(true)
  locadorId    Int
  locador      Usuario   @relation(fields: [locadorId], references: [id])
  horarios     Horario[]
  reservas     Reserva[]
  bloqueios    BloqueioQuadra[]
  quadraEsportes QuadraEsporte[]
}

// Tabela de Esportes
model Esporte {
  id    Int    @id @default(autoincrement())
  nome  String @unique
  quadraEsportes QuadraEsporte[]
}

// Tabela de relacionamento N-N entre Quadra e Esporte
model QuadraEsporte {
  quadraId  Int
  esporteId Int
  quadra    Quadra  @relation(fields: [quadraId], references: [id], onDelete: Cascade)
  esporte   Esporte @relation(fields: [esporteId], references: [id], onDelete: Cascade)

  @@id([quadraId, esporteId])
}

// Tabela de Horários de Funcionamento da Quadra
model Horario {
  id             Int    @id @default(autoincrement())
  quadraId       Int
  quadra         Quadra @relation(fields: [quadraId], references: [id])
  diaSemana      Int
  horaAbertura   String
  horaFechamento String
}

// Tabela de Bloqueios de Quadra (dias/horários que a quadra não funcionará)
model BloqueioQuadra {
  id            Int       @id @default(autoincrement())
  quadraId      Int
  quadra        Quadra    @relation(fields: [quadraId], references: [id], onDelete: Cascade)
  dataInicio    DateTime  @db.DateTime(6)
  dataFim       DateTime  @db.DateTime(6)
  motivo        String    @db.VarChar(200) // ex: "Feriado", "Manutenção", "Limpeza"
  descricao     String?   @db.Text
  horaInicio    String?   // HH:mm - Hora inicial do bloqueio no dia (se nulo, bloqueia todo o dia)
  horaFim       String?   // HH:mm - Hora final do bloqueio no dia (se nulo, bloqueia todo o dia)
  criadoEm      DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt

  @@index([quadraId])
  @@index([dataInicio])
  @@index([dataFim])
}

// Tabela de Reservas (Aluguéis)
model Reserva {
  id          Int           @id @default(autoincrement())
  quadraId    Int
  quadra      Quadra        @relation(fields: [quadraId], references: [id])
  locatarioId Int
  locatario   Usuario       @relation(fields: [locatarioId], references: [id])
  dataInicio  DateTime      @db.DateTime(6)
  dataFim     DateTime      @db.DateTime(6)
  valorTotal  Decimal       @db.Decimal(10, 2)
  status      StatusReserva @default(PENDENTE)
  timezoneOffset Int        @default(-180) // Offset em minutos (padrão: UTC-3)
  posicaoFila Int?          // Posição na fila de espera (null se não está em fila)
  dataOferta  DateTime?     // Data/hora quando foi ofertado ao locatário
  codigoSeguranca String?   // Código de segurança alfanumérico (4 dígitos) para verificação
  createdAt   DateTime      @default(now()) // Para ordenar FIFO
  // Rastreamento de lembretes enviados
  lembreteUmDiaEnviado   Boolean @default(false)  // 1 dia antes
  lembrete6HorasEnviado  Boolean @default(false)  // 6 horas antes
  lembrete3HorasEnviado  Boolean @default(false)  // 3 horas antes
  lembrete1HoraEnviado   Boolean @default(false)  // 1 hora antes
}

enum StatusReserva {
  PENDENTE
  AGUARDANDO_APROVACAO
  CANCELADO
  RESERVADO
  EM_FILA
  OFERECIDO_LOCATARIO
  BLOQUEADO
}